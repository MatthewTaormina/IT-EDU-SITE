{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "vfs:base": "node scripts/dump-base-vfs.mjs && node scripts/generate-vfs-manifests.mjs --layer base --src tmp/vfs-base --out public/vfs/base",
    "vfs:setup": "node scripts/generate-vfs-manifests.mjs --layer setup --src public/desktop-states/default/vfs.json --out public/vfs/setup",
    "vfs:active": "node scripts/generate-vfs-manifests.mjs --layer active --out public/vfs/active",
    "vfs:all": "npm run vfs:base && npm run vfs:setup && npm run vfs:active"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
